{
  "name": "noetfield-monorepo",
  "private": true,
  "version": "0.3.1",
  "description": "Noetfield governed intelligence platform monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:platform": "npm --workspace apps/platform run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:cognitive-dashboard": "npm --prefix governance-console/frontend run dev",
    "lint": "npm --workspaces --if-present run lint",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
