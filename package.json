{
  "name": "noetfield-monorepo",
  "private": true,
  "version": "0.3.1",
  "description": "Noetfield governed intelligence platform monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspace apps/web run build",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:platform": "npm --workspace apps/platform run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:cognitive-dashboard": "bash scripts/dev-cognitive-dashboard.sh",
    "lint": "npm --workspaces --if-present run lint",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "dependencies": {
    "@tailwindcss/postcss": "latest",
    "autoprefixer": "latest"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
