{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/noos-local-boot.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "python3 .cursor/hooks/noos-pr-conflict-guard.py",
        "matcher": "Write|StrReplace|Edit",
        "failClosed": true
      }
    ],
    "beforeFileEdit": [
      {
        "command": ".cursor/hooks/noos-claim-reminder.sh"
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/noos-heartbeat-reminder.sh",
        "matcher": "Write|Edit"
      }
    ]
  }
}
