  },
  "alert_channels": ["telegram"],
  "telegram_lane": {
    "one_law": "NOOS deadman ONLY. Never Gateway_A, NF Probe Bot, Signal Factory, or generic TELEGRAM_* env.",
    "secret_names_only": ["DEADMAN_TELEGRAM_BOT_TOKEN", "DEADMAN_TELEGRAM_CHAT_ID"],
