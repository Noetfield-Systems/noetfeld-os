  "supabase": {
    "registry_table": "noos_loop_registry",
    "receipts_table": "noos_deadman_runs"
  },
  "cf_worker": "noos-deadman-v1",
  "health_url": "https://noos-deadman-v1.sina-kazemnezhad-ca.workers.dev/health",
  "check_url": "https://noos-deadman-v1.sina-kazemnezhad-ca.workers.dev/check",
  "cf_workers_paid": {
    "active": true,
    "plan_usd_month": 5,
    "confirmed_at": "2026-07-06"
