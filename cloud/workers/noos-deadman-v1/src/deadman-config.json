    "probe_suppress_telegram": true,
    "founder_test_query_param": "telegram=1"
  },
  "restart_attempts_max": 1,
  "loop_runner": {
    "health_path": "/health",
    "loop_path": "/loop",
    "motor_restart_path": "/motor-restart"
  },
  "cf_loop_motor": {
    "health_url": "https://noos-loop-fleet-tick-v1.sina-kazemnezhad-ca.workers.dev/health",
