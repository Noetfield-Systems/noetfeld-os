# Noetfield v3.1 local development defaults.
# Do not commit real secrets. Use a secrets manager for shared environments.

NOETFIELD_ENV=local
NOETFIELD_SERVICE_NAME=noetfield-platform
NOETFIELD_LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/noetfield
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

REDIS_URL=redis://localhost:6379/0

OPA_URL=http://localhost:8181
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=replace-me
LANGFUSE_SECRET_KEY=replace-me

# Local dev only — see docs/strategy/local-ollama-agent-runtime-blueprint.md (LOCKED)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Website chatbot — server-side only; NEVER commit real keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# auto | gemini | openrouter — auto prefers OpenRouter when both keys are set
PUBLIC_CHAT_PROVIDER=auto
PUBLIC_CHAT_ENABLED=true
PUBLIC_INTAKE_ENABLED=true
INTAKE_PERSISTENCE=auto
INTAKE_OPS_WEBHOOK_URL=
REDIS_SESSIONS_ENABLED=true
PUBLIC_CHAT_CORS_ORIGINS=https://www.noetfield.com,https://noetfield.com,http://localhost:8080,http://127.0.0.1:8080

# Telegram bot (server-side only — revoke token if ever leaked)
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_BASE_URL=https://platform.noetfield.com
TELEGRAM_WEBHOOK_SECRET=
# Public @username for www footer link (no secret) — run scripts/publish_ecosystem_config.py
TELEGRAM_BOT_USERNAME=
PUBLIC_CHAT_API_BASE=https://platform.noetfield.com

EVENT_INTEGRITY_SECRET=replace-with-kms-managed-secret

# Governance pilot API (Tier 2) — server-side only
GOVERNANCE_PILOT_AUTH_REQUIRED=false
GOVERNANCE_PILOT_API_KEYS=
GOVERNANCE_WEBHOOK_URLS=
GOVERNANCE_WEBHOOK_SECRET=
PUBLIC_STATUS_PAGE_URL=https://www.noetfield.com/status/

# Phase 3.1 runtime persistence.
# PostgreSQL is the governance system of record. Use "memory" only for tests.
RUNTIME_EVENT_STORE=postgres
