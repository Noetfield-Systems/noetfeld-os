# NOOS Motor v1 — configuration reference (NO SECRETS IN THIS FILE)
# NF-NOOS-MOTOR-V1-FULL-RUNWAY, Phase 6.
#
# The local reference executor (noos demo / verify) needs NOTHING here — it is
# stdlib-only and fully offline. The variables below are ONLY for the cloud
# organic producer + authoritative Supabase store (EXTERNAL_ACTIVATION_REQUIRED).
# Real secret values live OUTSIDE the repo in ~/.noetfield-platform-secrets/ and
# are supplied by the founder-gated cloud-secrets-sync path — never commit them.

# ---- Local reference executor (offline; no value required) ----
# NOOS_MOTOR_ARTIFACT_DIR=receipts/runway/artifacts
# NOOS_MOTOR_RECEIPT_DIR=receipts/runway/executions

# ---- Authoritative store (Supabase) — cloud only ----
# SUPABASE_URL=<from ~/.noetfield-platform-secrets/noetfield.env>
# SUPABASE_SERVICE_ROLE_KEY=<secret; never in repo>
# NOOS_FACTORY_TABLE=noetfield_factory_cycle_runs

# ---- Cloud organic producer (Railway noos-loop-runner) — cloud only ----
# RAILWAY_LOOP_EXECUTOR_URL=<executor URL>
# LOOP_RUNNER_URL=<executor URL>
# NOOS_LOOP_SECRET=<secret; X-NOOS-Loop-Secret header; never in repo>

# ---- Motor tuning (safe defaults; override only with cause) ----
NOOS_MOTOR_COMPLETION_STALE_MINUTES=30
NOOS_MOTOR_DISPATCH_STALE_MULTIPLIER=2
NOOS_MOTOR_MAX_RETRIES=3
NOOS_MOTOR_RETRY_BACKOFF_BASE_SECONDS=5
NOOS_MOTOR_LEASE_TTL_SECONDS=120
