+#!/usr/bin/env python3
+"""NF Voyage AI live wire — L8 semantic embeddings + chatbot knowledge hybrid search.
+
+SourceA pattern: voyage_ai_live_wire_v1.py · INCIDENT-036 fake-green guard.
+Receipt: reports/agent-auto/events/nf-voyage-ai-live-wire-v1.json
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import sys
+from datetime import datetime, timezone
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+SCRIPTS = Path(__file__).resolve().parent
+if str(SCRIPTS) not in sys.path:
+    sys.path.insert(0, str(SCRIPTS))
+EVENTS = ROOT / "reports" / "agent-auto" / "events"
+DEFAULT_QUERY = "Copilot governance evidence Trust Ledger"
+
+
+def _now() -> str:
+    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+def _import_provider():
+    from nf_embedding_loader_v1 import load_embedding_provider
+
+    mod = load_embedding_provider(ROOT)
+    return mod.embed_text, mod.hybrid_score, mod.provider_payload
+
+
+def _load_knowledge_chunks() -> list[dict]:
+    manifest_path = ROOT / "data" / "chatbot" / "MANIFEST.json"
+    if not manifest_path.is_file():
+        return []
+    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
+    chunks: list[dict] = []
+    for name in manifest.get("knowledge_files") or []:
+        path = ROOT / "data" / "chatbot" / "knowledge" / name
+        if not path.is_file():
+            continue
+        text = path.read_text(encoding="utf-8", errors="replace").strip()
+        if len(text) < 40:
+            continue
+        chunks.append({"path": name, "text": text[:4000]})
+    return chunks
+
+
+def _token_score(query: str, text: str) -> float:
+    tokens = set(query.lower().split())
+    if not tokens:
+        return 0.0
+    lower = text.lower()
+    hits = sum(1 for t in tokens if len(t) > 2 and t in lower)
+    return round(hits / max(len(tokens), 1), 6)
+
+
+def _active_search(*, tier: str, query: str) -> dict:
+    embed_text, hybrid_score, provider_payload = _import_provider()
+    prov = provider_payload()
+    if not prov.get("semantic"):
+        return {"ok": True, "reason": "hash_local_fallback", "hits": 0, "mode": "fallback"}
+
+    try:
+        probe = embed_text(query, is_query=True)
+        if len(probe) < 8:
+            return {"ok": False, "reason": "empty_embedding", "hits": 0}
+    except Exception as exc:
+        return {"ok": False, "reason": str(exc), "hits": 0}
+
+    chunks = _load_knowledge_chunks()
+    if len(chunks) < 3:
+        return {"ok": True, "reason": "probe_only_index_building", "hits": 1, "mode": "probe", "chunk_count": len(chunks)}
+
+    sample = chunks if tier == "full" else chunks[:40]
+    scored: list[tuple[float, dict]] = []
+    for chunk in sample:
+        tok = _token_score(query, chunk["text"])
+        if prov.get("semantic"):
+            score = hybrid_score(token_score=tok, query=query, chunk_text=chunk["text"])
+        else:
+            score = tok
+        scored.append((score, chunk))
+    scored.sort(key=lambda x: -x[0])
+    hits = [c for s, c in scored if s > 0.01][:3]
+    top = hits[0] if hits else {}
+    top_score = scored[0][0] if scored else 0.0
+    return {
+        "ok": len(hits) >= 1,
+        "hits": len(hits),
+        "top_score": top_score,
+        "top_path": (top.get("path") or "")[:80],
+        "mode": "hybrid" if tier == "full" else "probe+hybrid",
+        "chunk_count": len(chunks),
+        "sampled_chunks": len(sample),
+        "query": query[:80],
+    }
+
+
+def _compose_line(*, provider: dict, search: dict, index_count: int) -> str:
+    mode = provider.get("mode") or "?"
+    model = provider.get("model") or "?"
+    hits = search.get("hits") or 0
+    if provider.get("ok") and search.get("ok"):
+        status = "ACTIVE"
+    elif provider.get("semantic"):
+        status = "READY"
+    elif provider.get("voyage_key_on_disk"):
+        status = "FAKE_GREEN"
+    else:
+        status = "FALLBACK"
+    return f"VOYAGE {status} · {mode} · {model} · chunks={index_count} · search={hits}hits · NF L8"
+
+
+def run_nf_voyage_ai_live_wire(*, tier: str = "session", query: str = DEFAULT_QUERY) -> dict:
+    _, _, provider_payload = _import_provider()
+    provider = provider_payload()
+    chunks = _load_knowledge_chunks()
+    search = _active_search(tier=tier, query=query)
+
+    ok = bool(provider.get("ok"))
+    if provider.get("voyage_key_on_disk"):
+        ok = ok and bool(provider.get("semantic"))
+    if len(chunks) >= 3 and provider.get("semantic"):
+        ok = ok and bool(search.get("ok"))
+
+    voyage_line = _compose_line(provider=provider, search=search, index_count=len(chunks))
+    receipt = {
+        "schema": "nf-voyage-ai-live-wire-v1",
+        "ok": ok,
+        "generated_at": _now(),
+        "tier": tier,
+        "law": "SourceA voyage_ai_live_wire_v1 · INCIDENT-036 fake-green guard",
+        "voyage_line": voyage_line,
+        "provider": provider,
+        "index": {"chunk_count": len(chunks), "ok": len(chunks) >= 3},
+        "search": search,
+        "paths": {
+            "embedding_provider": "services/governance/noetfield_governance/embedding_provider.py",
+            "knowledge_dir": "data/chatbot/knowledge",
+            "semantic_anchors": "data/chatbot/semantic_anchors_v1.json",
+        },
+    }
+    EVENTS.mkdir(parents=True, exist_ok=True)
+    out = EVENTS / "nf-voyage-ai-live-wire-v1.json"
+    out.write_text(json.dumps(receipt, indent=2) + "\n", encoding="utf-8")
+    return receipt
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description="NF Voyage AI live wire — L8 semantic + chatbot hybrid")
+    parser.add_argument("--tier", default="session", choices=["session", "full"])
+    parser.add_argument("--query", default=DEFAULT_QUERY)
+    parser.add_argument("--json", action="store_true")
+    args = parser.parse_args()
+    row = run_nf_voyage_ai_live_wire(tier=args.tier, query=args.query)
+    if args.json:
+        print(json.dumps(row, indent=2))
+    else:
+        print(f"NF_VOYAGE_LIVE_WIRE ok={row['ok']} line={row.get('voyage_line', '')[:96]}")
+    return 0 if row.get("ok") else 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
