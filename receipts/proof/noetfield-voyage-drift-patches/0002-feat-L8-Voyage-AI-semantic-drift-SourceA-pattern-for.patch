+"""Tests for L8 embedding provider (hash_local fallback when no API key)."""
+
+from __future__ import annotations
+
+import math
+
+from noetfield_governance.embedding_provider import (
+    cosine,
+    embed_text,
+    hybrid_score,
+    provider_payload,
+    voyage_key_on_disk,
+)
+
+
+def test_hash_local_embed_dimensions() -> None:
+    vec = embed_text("Copilot governance evidence")
+    assert len(vec) == 64
+    norm = math.sqrt(sum(v * v for v in vec))
+    assert 0.99 <= norm <= 1.01
+
+
+def test_cosine_identical_vectors() -> None:
+    a = embed_text("Trust Ledger Entry")
+    assert cosine(a, a) == 1.0
+
+
+def test_hybrid_score_bounded() -> None:
+    score = hybrid_score(token_score=0.5, query="gel runtime", chunk_text="GEL governance execution layer")
+    assert 0.0 <= score <= 1.5
+
+
+def test_provider_payload_schema() -> None:
+    payload = provider_payload()
+    assert payload["producer"] == "nf-L8-embedding-provider-v1"
+    assert "mode" in payload
+    assert "semantic" in payload
+    assert isinstance(voyage_key_on_disk(), bool)
