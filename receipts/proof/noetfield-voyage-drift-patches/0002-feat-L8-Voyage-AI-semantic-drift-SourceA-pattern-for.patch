+"""Load embedding_provider without importing noetfield_governance package __init__."""
+
+from __future__ import annotations
+
+import importlib.util
+import sys
+from pathlib import Path
+from types import ModuleType
+
+
+def load_embedding_provider(root: Path | None = None) -> ModuleType:
+    base = root or Path(__file__).resolve().parents[1]
+    path = base / "services" / "governance" / "noetfield_governance" / "embedding_provider.py"
+    name = "nf_embedding_provider_standalone"
+    if name in sys.modules:
+        return sys.modules[name]
+    spec = importlib.util.spec_from_file_location(name, path)
+    if spec is None or spec.loader is None:
+        raise ImportError(f"cannot load embedding provider from {path}")
+    mod = importlib.util.module_from_spec(spec)
+    sys.modules[name] = mod
+    spec.loader.exec_module(mod)
+    return mod
