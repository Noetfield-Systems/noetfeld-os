{
  "schema": "noos-24-7-loops-v1",
  "version": "1.0.0",
  "one_law": "All 24/7 loops → CF cron + Railway HTTP /loop (one bounded tick). No GitHub Actions runtime dispatch.",
  "slo_defaults": {
    "freshness_target_minutes": 30,
    "success_rate_target": 0.98,
    "latency_target_minutes": 60
  },
  "motor": {
    "cf_worker": "noos-loop-fleet-tick-v1",
    "cf_deadman": "noos-deadman-v1",
    "dispatch_table": "data/noos-cf-dispatch-table-v1.json",
    "base_cron": "*/5 * * * *",
    "health_url": "https://noos-loop-fleet-tick-v1.sina-kazemnezhad-ca.workers.dev/health",
    "deadman_health_url": "https://noos-deadman-v1.sina-kazemnezhad-ca.workers.dev/health",
    "railway_health_url": "https://noos-loop-runner-production.up.railway.app/health",
    "canonical_execution_plane": "railway:noos-loop-runner",
    "canonical_executor_url": "https://noos-loop-runner-production.up.railway.app",
    "live_execution_plane": "railway:noos-loop-runner",
    "live_executor_url": "https://noos-loop-runner-production.up.railway.app",
    "live_executor_status": "CANONICAL_LIVE",
    "execution_plane": "railway:noos-loop-runner",
    "cutover_status": "data/noos-executor-cutover-status-v1.json",
    "wiring_pattern": "data/noos-motor-executor-wiring-v1.json",
    "motor_restart_recipes": "data/noos-motor-restart-recipes-v1.json",
    "legacy_factory_motor": "noos-factory-autorun-tick-v1",
    "legacy_factory_motor_status": "cron_retired_2026-07-05",
    "secondary_motor": "fly_always_on",
    "secondary_motor_note": "noos-inbox-runner + noos-self-heal-runner on Fly (optional redundancy)"
  },
  "loops": [
    {
      "id": "inbox",
      "title": "Inbox drain loop",
      "domain": "factory-inbox",
      "lane": "noos",
      "value_class": "revenue_path",
      "event_type": "noos_inbox_loop_tick",
      "interval_minutes": 5,
      "github_workflow": "noos-inbox-loop.yml",
      "factory_id": "loop-inbox",
      "secondary_motor": "fly:noos-inbox-runner",
      "steps": [
        {"name": "cloud_worker", "cmd": ["python3", "scripts/cloud_inbox_worker_v1.py"]}
      ],
      "self_heal": [
        {"name": "reenqueue_blocked", "cmd": ["python3", "scripts/reenqueue_blocked_upg_inbox_v1.py"]}
      ]
    },
    {
      "id": "runtime",
      "title": "Runtime gate + pytest loop",
      "domain": "gel-runtime",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_runtime_loop_tick",
      "interval_minutes": 15,
      "github_workflow": "noos-runtime-loop.yml",
      "factory_id": "loop-runtime",
      "steps": [
        {"name": "gate", "cmd": ["python3", "-m", "noetfield_gate.cli", "gate", "--json", "--pytest"]},
        {"name": "pytest", "cmd": ["python3", "-m", "pytest", "-q"]}
      ],
      "cloud_steps": [
        {"name": "gate_smoke", "cmd": ["python3", "-m", "noetfield_gate.cli", "gate", "--json"], "continue_on_error": true},
        {"name": "import_smoke", "cmd": ["python3", "-c", "import noetfield_gate; print('ok')"]}
      ]
    },
    {
      "id": "surface",
      "title": "Public surface health loop",
      "domain": "public-nerve",
      "lane": "health",
      "value_class": "risk_reduction",
      "event_type": "noos_surface_loop_tick",
      "interval_minutes": 20,
      "github_workflow": "noos-surface-loop.yml",
      "factory_id": "loop-surface",
      "steps": [
        {"name": "production_urls", "cmd": ["bash", "scripts/check_production_urls.sh"]}
      ]
    },
    {
      "id": "chain",
      "title": "Chain tools verify loop",
      "domain": "chain-tools",
      "lane": "proof",
      "value_class": "proof_asset",
      "event_type": "noos_chain_loop_tick",
      "interval_minutes": 30,
      "github_workflow": "noos-chain-loop.yml",
      "factory_id": "loop-chain",
      "steps": [
        {"name": "verify", "cmd": ["python3", "-m", "noetfield_gate.cli", "verify", "--json"]},
        {
          "name": "decide_validate",
          "cmd": [
            "python3",
            "-m",
            "noetfield_gate.cli",
            "decide",
            "--file",
            "fixtures/demo_intents/approve.json",
            "--validate-only"
          ]
        }
      ]
    },
    {
      "id": "self_heal",
      "title": "Self-heal + autonomy nerve loop",
      "domain": "self-improvement",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_self_heal_loop_tick",
      "interval_minutes": 10,
      "github_workflow": "noos-self-heal-loop.yml",
      "factory_id": "loop-self-heal",
      "secondary_motor": "fly:noos-self-heal-runner",
      "steps": [
        {
          "name": "reenqueue_blocked",
          "cmd": ["python3", "scripts/reenqueue_blocked_upg_inbox_v1.py"]
        },
        {
          "name": "autonomy_verify",
          "cmd": ["python3", "scripts/verify_noos_autonomous_24h_v1.py", "--hours", "6", "--write-receipt"]
        },
        {
          "name": "autorun_status",
          "cmd": ["python3", "scripts/autorun_status_v1.py"]
        },
        {
          "name": "loop_heartbeat",
          "cmd": ["python3", "scripts/noos_loop_heartbeat_v1.py", "--write-receipt"]
        }
      ],
      "cloud_steps": [
        {"name": "reenqueue_blocked", "cmd": ["python3", "scripts/reenqueue_blocked_upg_inbox_v1.py"], "continue_on_error": true},
        {"name": "loop_heartbeat", "cmd": ["python3", "scripts/noos_loop_heartbeat_v1.py", "--write-receipt"], "continue_on_error": true}
      ]
    },
    {
      "id": "sourcea_observe",
      "title": "SourceA portfolio-spine observe loop",
      "domain": "sourcea-observe",
      "lane": "sourcea",
      "value_class": "hygiene",
      "event_type": "noos_sourcea_observe_loop_tick",
      "interval_minutes": 30,
      "github_workflow": "noos-sourcea-observe-loop.yml",
      "factory_id": "loop-sourcea-observe",
      "steps": [
        {
          "name": "sourcea_supabase_observe",
          "cmd": ["python3", "scripts/observe_sourcea_supabase_v1.py", "--write-receipt", "--json"]
        }
      ],
      "cloud_steps": [
        {
          "name": "sourcea_supabase_observe",
          "cmd": ["python3", "scripts/observe_sourcea_supabase_v1.py", "--write-receipt", "--json"],
          "continue_on_error": false
        }
      ]
    },
    {
      "id": "agent_nerve",
      "title": "Agent vault nerve loop",
      "domain": "agent-docs",
      "lane": "noos",
      "value_class": "hygiene",
      "event_type": "noos_agent_nerve_loop_tick",
      "interval_minutes": 60,
      "github_workflow": "noos-agent-nerve-loop.yml",
      "factory_id": "loop-agent-nerve",
      "steps": [
        {"name": "agent_docs", "cmd": ["bash", "scripts/check_noos_agent_docs.sh"]},
        {
          "name": "business_strategy",
          "cmd": ["bash", "scripts/check_noetfield_business_strategy.sh"]
        }
      ]
    },
    {
      "id": "workflow_audit",
      "title": "Workflow audit + critique loop",
      "domain": "workflow-governance",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_workflow_audit_tick",
      "interval_minutes": 15,
      "github_workflow": "noos-workflow-audit.yml",
      "factory_id": "loop-workflow-audit",
      "steps": [
        {
          "name": "workflow_audit",
          "cmd": ["python3", "scripts/noos_workflow_audit_v1.py", "--json"]
        }
      ],
      "cloud_steps": [
        {
          "name": "workflow_audit",
          "cmd": ["python3", "scripts/noos_workflow_audit_v1.py", "--json", "--loop-exit-ok"]
        }
      ]
    },
    {
      "id": "self_heal_safe_fixes",
      "title": "Auto-fix safe issues from audit findings",
      "domain": "self-improvement",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_self_heal_safe_fixes_tick",
      "interval_minutes": 30,
      "github_workflow": "noos-self-heal.yml",
      "factory_id": "loop-self-heal-safe-fixes",
      "steps": [
        {
          "name": "execute_safe_fixes",
          "cmd": ["python3", "scripts/noos_self_heal_v1.py", "--findings-file", "data/noos-audit-findings-v1.json"]
        }
      ]
    },
    {
      "id": "researcher_deep_dive",
      "title": "Deep-dive investigation of escalated findings",
      "domain": "self-improvement",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_researcher_deep_dive_tick",
      "interval_minutes": 60,
      "github_workflow": "noos-researcher.yml",
      "factory_id": "loop-researcher",
      "steps": [
        {
          "name": "investigate_escalations",
          "cmd": ["python3", "scripts/noos_researcher_v1.py", "--depth", "standard"]
        }
      ]
    },
    {
      "id": "specialist_proposals",
      "title": "Generate fix proposals from research",
      "domain": "self-improvement",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_specialist_proposals_tick",
      "interval_minutes": 120,
      "github_workflow": "noos-specialist.yml",
      "factory_id": "loop-specialist",
      "steps": [
        {
          "name": "generate_proposals",
          "cmd": ["python3", "scripts/noos_specialist_v1.py"]
        }
      ]
    },
    {
      "id": "orchestrator_cross_repo",
      "title": "Cross-repo health orchestration & consolidation",
      "domain": "self-improvement",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_orchestrator_cross_repo_tick",
      "interval_minutes": 180,
      "github_workflow": "noos-cross-repo-orchestrator.yml",
      "factory_id": "loop-orchestrator",
      "steps": [
        {
          "name": "aggregate_health",
          "cmd": ["echo", "Aggregating health across all org repos"]
        }
      ]
    },
    {
      "id": "role_circle",
      "title": "Hourly NOOS role circle — all required loops input→valuable output",
      "domain": "fleet-supervision",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_role_circle_tick",
      "interval_minutes": 60,
      "github_workflow": "noos-role-circle.yml",
      "factory_id": "loop-role-circle",
      "registry": "data/noos-role-circle-v1.json",
      "steps": [
        {
          "name": "role_circle",
          "cmd": ["python3", "scripts/noos_role_circle_tick_v1.py", "--json"]
        }
      ],
      "cloud_steps": [
        {
          "name": "role_circle",
          "cmd": ["python3", "scripts/noos_role_circle_tick_v1.py", "--json"]
        }
      ],
      "self_heal": [
        {
          "name": "reconcile_retry",
          "cmd": ["python3", "scripts/noos_machine_loops_v1.py", "--json", "reconcile"]
        }
      ]
    },
    {
      "id": "improve_kaizen_daily",
      "title": "Nightly machine_safe kaizen recipe slot",
      "domain": "self-improvement",
      "lane": "noos",
      "value_class": "risk_reduction",
      "event_type": "noos_improve_kaizen_daily_tick",
      "interval_minutes": 1440,
      "github_workflow": "noos-improve-kaizen-daily.yml",
      "factory_id": "loop-improve-kaizen",
      "steps": [
        {
          "name": "kaizen_daily",
          "cmd": ["python3", "scripts/noos_improve_kaizen_runner_v1.py", "--write-receipt", "--json"]
        },
        {
          "name": "recipe_apply_if_matched",
          "cmd": ["python3", "scripts/noos_kaizen_recipe_apply_v1.py", "--recipe-id", "seed-all-loop-ticks", "--dry-run", "--json"]
        }
      ]
    }
  ]
}
