{
  "schema": "autorun-workflows-v1",
  "version": "1.3.0",
  "read_only": true,
  "one_law": "Observe autorun surfaces only. phase_reconciler_v1 remains sole control authority.",
  "sourcea_truth_lane": "Supabase only (truth_log, cycle_receipts, heartbeat). Never read SourceA repo or ~/.sina.",
  "control_authority": {
    "sole_reconciler": "SourceA/scripts/phase_reconciler_v1.py",
    "noos_writes_desired_state": false,
    "noos_starts_sourcea_batch": false
  },
  "supabase_profiles": {
    "noetfield": {
      "env_file": "~/.sourcea-secrets/noetfield.env",
      "url_env": ["NOETFIELD_SUPABASE_URL", "SUPABASE_URL"],
      "key_env": ["NOETFIELD_SUPABASE_SERVICE_ROLE_KEY", "SUPABASE_SERVICE_ROLE_KEY"]
    },
    "portfolio_spine": {
      "env_file": "~/.sourcea-secrets/portfolio-spine.env",
      "url_env": ["SUPABASE_URL"],
      "key_env": ["SUPABASE_SERVICE_ROLE_KEY", "SUPABASE_SERVICE_KEY"]
    }
  },
  "stale_threshold_minutes": 30,
  "status_values": [
    "RUNNING",
    "IDLE_NO_WORK",
    "BLOCKED_WITH_REASON",
    "COMPLETE",
    "FAILED_WITH_RECEIPT",
    "TRIAGE_REQUIRED"
  ],
  "workflows": [
    {
      "id": "sourcea_cloud_queue",
      "title": "SourceA cloud queue",
      "plane": "SourceA",
      "probe": {
        "type": "supabase_sourcea_cloud_queue",
        "supabase_profile": "portfolio_spine",
        "truth_log_table": "truth_log",
        "cycle_table": "cycle_receipts",
        "cycle_fallback_table": "telemetry_logs",
        "cycle_fallback_memory_type": "truth_cycle_receipt",
        "cycle_id_contains": "CLOUD-SEC",
        "heartbeat_events": ["CRON_FIRED", "QUEUE_ADVANCED", "JOB_STARTED", "JOB_COMPLETED"]
      },
      "blocked_command": "Apply portfolio-spine truth_log migration; cloud writers emit CRON_FIRED + cycle receipts."
    },
    {
      "id": "sourcea_buyer_proof_verify",
      "title": "SourceA buyer-proof verify",
      "plane": "SourceA",
      "probe": {
        "type": "supabase_sourcea_receipt",
        "supabase_profile": "portfolio_spine",
        "cycle_table": "cycle_receipts",
        "cycle_fallback_table": "telemetry_logs",
        "cycle_fallback_memory_type": "truth_cycle_receipt",
        "receipt_schema": "buyer-proof-hotfix-verify-v1",
        "metadata_contains": ["buyer-proof", "buyer_proof"],
        "execution_id_contains": ["buyer-proof", "buyer_proof"]
      },
      "verify_command": "cd ~/Desktop/SourceA && python3 scripts/verify_buyer_proof_hotfix_v1.py --json"
    },
    {
      "id": "sourcea_recipe_queue_builder",
      "title": "SourceA recipe queue builder",
      "plane": "SourceA",
      "probe": {
        "type": "supabase_sourcea_receipt",
        "supabase_profile": "portfolio_spine",
        "cycle_table": "cycle_receipts",
        "cycle_fallback_table": "telemetry_logs",
        "cycle_fallback_memory_type": "truth_cycle_receipt",
        "receipt_schema": "client-proof-recipe-queue-v1",
        "metadata_contains": ["client-proof-recipe", "recipe-queue", "recipe_queue"],
        "execution_id_contains": ["recipe-queue", "recipe_queue", "client-proof-recipe"],
        "pending_metadata_fields": ["pending_count", "backlog_count", "queued_count"]
      },
      "build_command": "cd ~/Desktop/SourceA && python3 scripts/build_client_proof_recipe_queue_v1.py"
    },
    {
      "id": "noos_factory_autorun",
      "title": "Noetfield OS factory autorun",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_factory",
        "supabase_profile": "noetfield",
        "supabase_table": "noetfield_factory_cycle_runs",
        "github_workflow": "noos-factory-autorun.yml",
        "github_workflows_schedule": [
          "noos-factory-autorun.yml",
          "noos-schedule-canary.yml"
        ],
        "idle_statuses": ["IDLE_NO_WORK", "idle_no_work"]
      },
      "run_command": "make autorun-once"
    },
    {
      "id": "noos_worker_inbox",
      "title": "Noetfield worker inbox",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_inbox",
        "supabase_profile": "noetfield",
        "supabase_table": "noetfield_worker_inbox_queue",
        "founder_blocked_status": "founder_blocked",
        "executable_statuses": ["pending"]
      },
      "run_command": "make cloud-worker"
    },
    {
      "id": "noos_factory_autorun_tick",
      "title": "NOOS factory autorun CF tick",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "url_sweep_readonly",
        "urls": [
          {
            "name": "cf tick health",
            "url": "https://noos-factory-autorun-tick-v1.sina-kazemnezhad-ca.workers.dev/health"
          }
        ]
      }
    },
    {
      "id": "noos_schedule_canary",
      "title": "NOOS schedule canary",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "github_schedule_probe",
        "github_workflow": "noos-schedule-canary.yml"
      }
    },
    {
      "id": "noos_loop_fleet_tick",
      "title": "NOOS 24/7 loop fleet CF tick",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "url_sweep_readonly",
        "urls": [
          {
            "name": "loop fleet health",
            "url": "https://noos-loop-fleet-tick-v1.sina-kazemnezhad-ca.workers.dev/health"
          }
        ]
      }
    },
    {
      "id": "noos_loop_inbox",
      "title": "24/7 loop — inbox drain",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_loop",
        "supabase_profile": "noetfield",
        "supabase_table": "noetfield_factory_cycle_runs",
        "factory_id": "loop-inbox",
        "loop_id": "inbox",
        "github_workflow": "noos-inbox-loop.yml"
      },
      "run_command": "python3 scripts/noos_loop_runner_v1.py --event-type noos_inbox_loop_tick"
    },
    {
      "id": "noos_loop_runtime",
      "title": "24/7 loop — runtime gate+pytest",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_loop",
        "supabase_profile": "noetfield",
        "factory_id": "loop-runtime",
        "loop_id": "runtime",
        "github_workflow": "noos-runtime-loop.yml"
      },
      "run_command": "python3 scripts/noos_loop_runner_v1.py --event-type noos_runtime_loop_tick"
    },
    {
      "id": "noos_loop_surface",
      "title": "24/7 loop — public surface",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_loop",
        "supabase_profile": "noetfield",
        "factory_id": "loop-surface",
        "loop_id": "surface",
        "github_workflow": "noos-surface-loop.yml"
      },
      "run_command": "python3 scripts/noos_loop_runner_v1.py --event-type noos_surface_loop_tick"
    },
    {
      "id": "noos_loop_chain",
      "title": "24/7 loop — chain tools",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_loop",
        "supabase_profile": "noetfield",
        "factory_id": "loop-chain",
        "loop_id": "chain",
        "github_workflow": "noos-chain-loop.yml"
      },
      "run_command": "python3 scripts/noos_loop_runner_v1.py --event-type noos_chain_loop_tick"
    },
    {
      "id": "noos_loop_self_heal",
      "title": "24/7 loop — self-heal nerve",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_loop",
        "supabase_profile": "noetfield",
        "factory_id": "loop-self-heal",
        "loop_id": "self_heal",
        "github_workflow": "noos-self-heal-loop.yml"
      },
      "run_command": "python3 scripts/noos_loop_runner_v1.py --event-type noos_self_heal_loop_tick"
    },
    {
      "id": "noos_loop_agent_nerve",
      "title": "24/7 loop — agent vault nerve",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "supabase_noos_loop",
        "supabase_profile": "noetfield",
        "factory_id": "loop-agent-nerve",
        "loop_id": "agent_nerve",
        "github_workflow": "noos-agent-nerve-loop.yml"
      },
      "run_command": "python3 scripts/noos_loop_runner_v1.py --event-type noos_agent_nerve_loop_tick"
    },
    {
      "id": "noos_loop_sourcea_observe",
      "title": "24/7 loop — SourceA observe",
      "plane": "SourceA",
      "probe": {
        "type": "supabase_noos_loop",
        "supabase_profile": "noetfield",
        "factory_id": "loop-sourcea-observe",
        "loop_id": "sourcea_observe",
        "github_workflow": "noos-sourcea-observe-loop.yml"
      },
      "run_command": "python3 scripts/noos_loop_runner_v1.py --event-type noos_sourcea_observe_loop_tick"
    },
    {
      "id": "sandbox_health_sweep",
      "title": "Sandbox health sweep",
      "plane": "NOETFELD-OS",
      "probe": {
        "type": "url_sweep_readonly",
        "urls": [
          {"name": "www home", "url": "https://www.noetfield.com/"},
          {"name": "www gel", "url": "https://www.noetfield.com/gel/"},
          {"name": "www ai-value-os", "url": "https://www.noetfield.com/ai-value-governance-os/"},
          {"name": "platform health", "url": "https://platform.noetfield.com/health"},
          {"name": "gel-api health", "url": "https://api.noetfield.com/health"},
          {"name": "gel-api readiness", "url": "https://api.noetfield.com/readiness"}
        ]
      }
    }
  ]
}
