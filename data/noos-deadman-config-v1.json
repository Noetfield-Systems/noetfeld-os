{
  "schema": "noos-deadman-config-v1",
  "version": "1.0.0",
  "cron": "*/30 * * * *",
  "interval_multipliers": {
    "default": 2
  },
  "alert_channels": [
    "telegram"
  ],
  "telegram_lane": {
    "one_law": "NOOS deadman ONLY. Never Gateway_A, NF Probe Bot, Signal Factory, or generic TELEGRAM_* env.",
    "secret_names_only": [
      "DEADMAN_TELEGRAM_BOT_TOKEN",
      "DEADMAN_TELEGRAM_CHAT_ID"
    ],
    "forbidden_bot_usernames": [
      "Gateway_A",
      "gateway_a",
      "NFProbeBot",
      "nf_probe_bot",
      "NoetfieldOpsBot"
    ],
    "allowed_bot_username": "",
    "send_alerts": false,
    "probe_suppress_telegram": true,
    "founder_test_query_param": "telegram=1"
  },
  "restart_attempts_max": 5,
  "loop_runner": {
    "health_path": "/health",
    "loop_path": "/loop",
    "motor_restart_path": "/motor-restart"
  },
  "cf_loop_motor": {
    "health_url": "https://noos-loop-fleet-tick-v1.sina-kazemnezhad-ca.workers.dev/health",
    "restart_recipe_id": "cf-loop-motor"
  },
  "motor_restart_recipes_path": "data/noos-motor-restart-recipes-v1.json",
  "heartbeat_summary_hours_utc": [
    6,
    12,
    18,
    0
  ],
  "supabase": {
    "registry_table": "noos_loop_registry",
    "receipts_table": "noos_deadman_runs"
  },
  "cf_worker": "noos-deadman-v1",
  "health_url": "https://noos-deadman-v1.sina-kazemnezhad-ca.workers.dev/health",
  "check_url": "https://noos-deadman-v1.sina-kazemnezhad-ca.workers.dev/check",
  "cf_workers_paid": {
    "active": true,
    "plan_usd_month": 5,
    "confirmed_at": "2026-07-06"
  },
  "external_monitors_registry": "data/noos-external-monitors-v1.json",
  "unified_motor_event_gateway": {
    "health_url_env": "MOTOR_EVENT_GATEWAY_URL",
    "health_path": "/health",
    "readiness_path": "/readiness",
    "role_id": "noetfield:noos.portfolio-owner",
    "bridge_loop_id": "unified_motor_event_bridge",
    "bridge_interval_minutes": 15,
    "receipt_path": "receipts/proof/noos-unified-motor-event-bridge-v1.json",
    "note": "Deadman probes gateway health/readiness at 2x bridge interval; bridge liveness via noos_loop_registry"
  },
  "github_events_receiver": {
    "worker": "noos-loop-github-events-v1",
    "active": false,
    "mode": "rollback_fallback_only"
  },
  "external_loops": {
    "nf_commissioning_specialist": {
      "loop_id": "nf-commissioning-specialist-tick-v1",
      "interval_minutes": 5,
      "health_url": "https://nf-commissioning-specialist-tick-v1.sina-kazemnezhad-ca.workers.dev/health",
      "restart_url": "https://nf-commissioning-specialist-tick-v1.sina-kazemnezhad-ca.workers.dev/tick",
      "restart_method": "POST",
      "staleness_multiplier": 2,
      "note": "SG commissioning specialist CF cron every 5m; deadman at 2x interval"
    }
  }
}
