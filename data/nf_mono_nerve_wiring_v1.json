    "nf_session_gate_run_v1.py mono_gates",
    "nf_stale_guard_v1.py mono_staleness",
    "nf_live_surfaces_v1.py commercial_blockers",
    "nf_gatekeeper_v1.py EMAIL_SEND_DEFERRED",
    "nf_receipt_cascade_v1.json nf_mono_nerve",
    "nf_truth_bundle_v1.json mono_nerve"
  ],
  "email_task_denial_patterns": [
    "resend",
    "auto-notify",
    "auto_notify",
    "w3_send",
    "outreach",
    "commercial_email",
    "send_w3",
    "mail_from",
    "form_autonotify"
