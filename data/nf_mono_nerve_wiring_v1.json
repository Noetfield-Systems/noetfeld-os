    {"id": "defer_receipt", "sina": "commercial-email-send-defer-receipt-v1.json", "required_line": "email_send_defer_line"},
    {"id": "agent_live_surfaces", "sina": "agent-live-surfaces-v1.json", "inherit": ["email_send_defer_line", "truth_bundle_at"]},
    {"id": "agent_nerve_receipt", "sina": "agent-nerve-system-receipt-v1.json", "inherit": ["ship_gates.email_send_defer_line"]},
    {"id": "tf_live_surfaces", "sina": "tf-live-surfaces-v1.json", "inherit": ["email_send_defer_line"]},
    {"id": "operations_inbox", "sina": "noetfield-operations-inbox-active-v1.json", "sync_from": "docs/ops/COMMERCIAL_INBOX_PACKAGING_LOCKED_v1.md"},
    {"id": "founder_cascade", "sina": "founder-input-cascade-events.jsonl", "staleness_probe": true},
    {"id": "nf_inbox", "path": "~/.sina/agent-workspaces/noetfield_cloud/INBOX.md", "required": true},
    {"id": "trustfield_fleet_wire", "command": "python3 ~/Desktop/TrustField Technologies/scripts/tf_fleet_live_wire_v1.py --json --no-refresh", "required": true},
    {"id": "ecosystem_nerve", "sina": "ecosystem-live-nerve-v1.json", "required": true},
