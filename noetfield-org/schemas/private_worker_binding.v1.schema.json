{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noetfield.org/schemas/private_worker_binding.v1.json",
  "title": "Private Worker Binding v1",
  "description": "Non-canonical deployment binding. Provider/model names allowed here only. Worker class aliases map to canonical lanes per P7 section 12.",
  "type": "object",
  "required": [
    "binding_id",
    "worker_class",
    "mode",
    "capabilities",
    "invocation",
    "credential_ref",
    "cost"
  ],
  "properties": {
    "binding_id": { "type": "string" },
    "worker_class": {
      "type": "string",
      "description": "Advisor classes W-DET-EXEC, W-INTEL-FREE, etc. accepted; map to W-DET / W-INTEL-LOW / W-INTEL-BOUNDED in receipts",
      "enum": [
        "W-DET",
        "W-DET-EXEC",
        "W-DET-PATCH",
        "W-INTEL-LOW",
        "W-INTEL-FREE",
        "W-INTEL-BOUNDED",
        "W-HANDOFF",
        "W-VERIFY-RECOMPUTE",
        "W-VERIFY-CI",
        "W-VERIFY-EDGE"
      ]
    },
    "canonical_lane": {
      "enum": ["W-DET", "W-INTEL-LOW", "W-INTEL-BOUNDED", "FOUNDER_REASONING_QUEUE"],
      "description": "Normalized lane for routing — set by adapter registry"
    },
    "cost_tier": {
      "enum": ["COST-T0", "COST-T1", "COST-T2"],
      "description": "Motor cost tier for this binding"
    },
    "mode": { "enum": ["callable", "handoff"] },
    "provider": { "type": "string" },
    "model_or_service": { "type": "string" },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "invocation": { "type": "object" },
    "credential_ref": { "type": ["string", "null"] },
    "health_check": { "type": "object" },
    "max_concurrency": { "type": "integer", "minimum": 1 },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "cost": { "type": "object" },
    "enabled": { "type": "boolean" }
  },
  "additionalProperties": true
}
