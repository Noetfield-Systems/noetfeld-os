{
  "remote.autoForwardPorts": true,
  "remote.autoForwardPortsSource": "hybrid",
  "remote.autoForwardPortsFallback": 0,
  "remote.otherPortsAttributes": {
    "3000": { "onAutoForward": "ignore" },
    "13000": { "onAutoForward": "ignore" },
    "18002": { "onAutoForward": "ignore" }
  },
  "remote.portsAttributes": {
    "13080": {
      "label": "Noetfield (website + all apps)",
      "onAutoForward": "openBrowser",
      "uriFormat": "http://localhost:${port}/"
    },
    "8001": {
      "label": "Governance console (legacy port)",
      "onAutoForward": "notify",
      "uriFormat": "http://localhost:${port}/console"
    }
  }
}
