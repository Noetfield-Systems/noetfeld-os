{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Noetfield localhost (port 13080)",
      "type": "shell",
      "command": "make dev-local",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "runOptions": { "runOn": "folderOpen" },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Noetfield local dev",
          "endsPattern": "All checks passed|━━━"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
