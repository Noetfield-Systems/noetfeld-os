{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.noetfield.com/rag-answer.schema.json",
  "title": "Noetfield RAG Answer (evidence-first)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "answer",
    "evidence",
    "sources",
    "confidence",
    "verification_status"
  ],
  "properties": {
    "answer": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "excerpt"],
        "properties": {
          "ref": { "type": "string" },
          "excerpt": { "type": "string" },
          "rid": { "type": "string" },
          "control_id": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["uri", "title"],
        "properties": {
          "uri": { "type": "string" },
          "title": { "type": "string" },
          "freshness": { "type": "string", "format": "date-time" }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "verification_status": {
      "type": "string",
      "enum": ["unverified", "pending", "verified", "rejected"]
    },
    "policy_version": { "type": "string" },
    "metadata": { "type": "object" }
  }
}
