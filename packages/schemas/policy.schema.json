{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.noetfield.com/policy.schema.json",
  "title": "Noetfield Policy Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_id", "version", "title", "tenant_scope", "controls", "status"],
  "properties": {
    "policy_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "tenant_scope": {
      "type": "string",
      "enum": ["global", "tenant", "pilot"]
    },
    "pack_type": {
      "type": "string",
      "enum": ["copilot-governance", "bank-pilot", "custom"]
    },
    "controls": {
      "type": "array",
      "items": { "type": "string", "description": "control_id references" },
      "minItems": 1
    },
    "evidence_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "effective_from": { "type": "string", "format": "date" },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "retired"]
    },
    "metadata": { "type": "object" }
  }
}
